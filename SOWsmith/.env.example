# Bid Package Generator — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit secrets.
#
# If the Azure OpenAI variables below are left blank, the reference engine runs in
# DETERMINISTIC OFFLINE MOCK mode (good for tests, CI and a no-secrets demo of the
# plumbing). Set them to run real grounded generation against Azure OpenAI (GPT-4).

# --- Azure OpenAI (optional) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Paths (optional overrides; sensible defaults derive from the repo root) ---
# BIDPKG_KB_ROOT=./knowledge-base/sharepoint-online-knowledge-base
# BIDPKG_OUT_ROOT=./var/run

# --- Client placeholder used inside the system prompt ---
BIDPKG_CLIENT_NAME=SOWsmith
